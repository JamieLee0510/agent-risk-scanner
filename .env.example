# Copy to `.env` (gitignored) and fill in real values, then before running:
#   source .env && agent-risk-scan run --agent ... --case ...
# The scanner forwards these into the agent container via `docker run -e NAME`;
# the values are never written to any file inside the image.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...      # examples/claudecode

# Codex (examples/codex) authenticates from its OWN env var, not OPENAI_API_KEY.
# The value is still an ordinary OpenAI key:
CODEX_API_KEY=${OPENAI_API_KEY}
